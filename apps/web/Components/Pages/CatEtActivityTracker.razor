@page "/catet/activity"
@attribute [Authorize(Policy = AppPermissions.ActivityTracker)]
@using web.Models
@using web.Services
@inject CatEtApiClient Api
@inject ISnackbar Snackbar

<PageTitle>CAT ET Activity Tracker</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">CAT ET Activity Tracker</MudText>

<MudPaper Class="pa-3 mb-3" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField T="string"
                          @bind-Value="_search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Variant="Variant.Outlined"
                          Placeholder="Filter by serial, event, computer, user, notes..." />
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadAsync" Disabled="_isLoading">Refresh</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-2" Elevation="1">
    <MudTable Items="SortedFilteredRows" Hover="true" Dense="true" Loading="_isLoading" RowsPerPage="25">
        <HeaderContent>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.OccurredAt)">When (UTC) @SortGlyph(SortColumn.OccurredAt)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.SerialNumber)">Serial Number @SortGlyph(SortColumn.SerialNumber)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.EventType)">Event @SortGlyph(SortColumn.EventType)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.Computer)">Computer @SortGlyph(SortColumn.Computer)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.User)">User @SortGlyph(SortColumn.User)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => SetSort(SortColumn.Notes)">Notes @SortGlyph(SortColumn.Notes)</MudButton></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="When (UTC)">@context.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
            <MudTd DataLabel="Serial Number">@context.SerialNumber</MudTd>
            <MudTd DataLabel="Event">@context.EventType</MudTd>
            <MudTd DataLabel="Computer">@FormatComputer(context)</MudTd>
            <MudTd DataLabel="User">@(string.IsNullOrWhiteSpace(context.TrackedPersonName) ? "Unassigned" : context.TrackedPersonName)</MudTd>
            <MudTd DataLabel="Notes">@(string.IsNullOrWhiteSpace(context.Notes) ? "-" : context.Notes)</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No activity events found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<CatEtActivationActivityRowDto> _rows = [];
    private bool _isLoading = true;
    private string _search = string.Empty;

    private SortColumn _sortColumn = SortColumn.OccurredAt;
    private bool _sortDescending = true;

    private IEnumerable<CatEtActivationActivityRowDto> FilteredRows
        => _rows.Where(MatchesSearch);

    private IEnumerable<CatEtActivationActivityRowDto> SortedFilteredRows
        => ApplySort(FilteredRows);

    protected override async Task OnInitializedAsync()
        => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _rows = (await Api.GetActivityEventsAsync()).ToList();
        }
        catch
        {
            Snackbar.Add("Failed to load activity tracker.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool MatchesSearch(CatEtActivationActivityRowDto row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        var needle = _search.Trim();
        return Contains(row.SerialNumber, needle)
               || Contains(row.EventType, needle)
               || Contains(row.Hostname, needle)
               || Contains(row.AssetTag, needle)
               || Contains(row.TrackedPersonName, needle)
               || Contains(row.Notes, needle);
    }

    private static bool Contains(string? value, string needle)
        => !string.IsNullOrWhiteSpace(value)
           && value.Contains(needle, StringComparison.OrdinalIgnoreCase);

    private static string FormatComputer(CatEtActivationActivityRowDto row)
        => string.IsNullOrWhiteSpace(row.Hostname)
            ? "Unassigned"
            : string.IsNullOrWhiteSpace(row.AssetTag)
                ? row.Hostname!
                : $"{row.Hostname} ({row.AssetTag})";

    private void SetSort(SortColumn column)
    {
        if (_sortColumn == column)
        {
            _sortDescending = !_sortDescending;
            return;
        }

        _sortColumn = column;
        _sortDescending = false;
    }

    private string SortGlyph(SortColumn column)
        => _sortColumn == column ? (_sortDescending ? "↓" : "↑") : string.Empty;

    private IEnumerable<CatEtActivationActivityRowDto> ApplySort(IEnumerable<CatEtActivationActivityRowDto> source)
    {
        var sorted = _sortColumn switch
        {
            SortColumn.OccurredAt => source.OrderBy(x => x.OccurredAtUtc),
            SortColumn.SerialNumber => source.OrderBy(x => x.SerialNumber),
            SortColumn.EventType => source.OrderBy(x => x.EventType),
            SortColumn.Computer => source.OrderBy(x => x.Hostname).ThenBy(x => x.AssetTag),
            SortColumn.User => source.OrderBy(x => x.TrackedPersonName),
            SortColumn.Notes => source.OrderBy(x => x.Notes),
            _ => source.OrderBy(x => x.OccurredAtUtc)
        };

        return _sortDescending ? sorted.Reverse() : sorted;
    }

    private enum SortColumn
    {
        OccurredAt,
        SerialNumber,
        EventType,
        Computer,
        User,
        Notes
    }
}
