@page "/assets/computers"
@attribute [Authorize(Policy = AppPermissions.Computers)]
@inject CatEtApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>CAT ET Computers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">CAT ET - Computers</MudText>

<MudPaper Class="pa-4 mb-4 people-form-card" Elevation="1">
    <div class="people-form-header">
        <div>
            <MudText Typo="Typo.h6">@(_editingComputerId is null ? "Add Computer" : "Edit Computer")</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mb-4">@(_editingComputerId is null ? "Create a computer record here, then assign it to a person if needed." : "Update the computer details here without jumping to a second card.")</MudText>
        </div>
        @if (_editingComputerId is not null)
        {
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Editing record</MudChip>
        }
    </div>
    <MudGrid Spacing="3" Class="people-form-grid">
        <MudItem xs="12" sm="6" lg="3">
            <MudTextField @bind-Value="ComputerFormHostname" Label="Hostname" Variant="Variant.Outlined" Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudTextField @bind-Value="ComputerFormAssetTag" Label="Asset Tag" Variant="Variant.Outlined" Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudAutocomplete T="TrackedPersonDto"
                             Value="ComputerFormPerson"
                             ValueChanged="OnComputerPersonChanged"
                             Label="Assigned User (optional)"
                             Variant="Variant.Outlined"
                             SearchFunc="SearchPeopleAsync"
                             ToStringFunc="FormatPersonOption"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             CoerceText="false"
                             Dense="true"
                             MaxItems="50"
                             Placeholder="Type to filter users" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            @if (_editingComputerId is not null)
            {
                <MudSelect T="string" @bind-Value="ComputerFormCategory" Label="Category" Variant="Variant.Outlined">
                    @foreach (var category in _assignableCategories)
                    {
                        <MudSelectItem Value="@category">@category</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField Value='@("Computer")' Label="Category" Variant="Variant.Outlined" ReadOnly="true" />
            }
        </MudItem>
        <MudItem xs="12">
            <div class="people-form-actions">
                @if (_editingComputerId is not null)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" Class="people-form-secondary-action" OnClick="CancelEdit" Disabled="_isSaving">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="people-form-action" OnClick="SaveEditAsync" Disabled="_isSaving">Save changes</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="people-form-action" OnClick="CreateComputerAsync" Disabled="_isSaving">Add computer</MudButton>
                }
            </div>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-2" Elevation="1">
    <MudGrid Class="pa-2">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search hostname, asset tag, or assigned user"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          OnDebounceIntervalElapsed="OnSearchDebounced"
                          DebounceInterval="350" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Value="_assignmentFilter"
                       ValueChanged="OnAssignmentFilterChanged"
                       Label="Assignment filter"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value='@("all")'>All computers</MudSelectItem>
                <MudSelectItem Value='@("assigned")'>Assigned only</MudSelectItem>
                <MudSelectItem Value='@("unassigned")'>Unassigned only</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Value="_visibilityFilter"
                       ValueChanged="OnVisibilityFilterChanged"
                       Label="Visibility"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value='@("visible")'>Visible only</MudSelectItem>
                <MudSelectItem Value='@("all")'>All</MudSelectItem>
                <MudSelectItem Value='@("hidden")'>Hidden only</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>
    <MudTable T="TrackedComputerDto"
              @ref="_computersTable"
              ServerData="LoadComputersServerData"
              Hover="true"
              Dense="true"
              Loading="_isLoading"
              RowsPerPage="25"
              RowsPerPageChanged="OnRowsPerPageChanged">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="TrackedComputerDto" SortLabel="hostname">Hostname</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedComputerDto" SortLabel="assetTag">Asset Tag</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedComputerDto" SortLabel="assignee">Assigned User</MudTableSortLabel></MudTh>
            <MudTh>Category</MudTh>
            <MudTh><MudTableSortLabel T="TrackedComputerDto" SortLabel="createdAt">Created (UTC)</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @context.Hostname
                @if (context.IsMobileDevice)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="ms-1">Mobile</MudChip>
                }
                @if (context.ExcludeFromSync)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="ms-1">Sync Excluded</MudChip>
                }
                @if (context.HiddenFromTable)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" Class="ms-1">Hidden</MudChip>
                }
            </MudTd>
            <MudTd>@context.AssetTag</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.TrackedPersonName) ? "Unassigned" : context.TrackedPersonName)</MudTd>
            <MudTd>@context.AssetCategory</MudTd>
            <MudTd>@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => BeginEdit(context)">Edit</MudButton>
                <MudButton Variant="Variant.Text" Color="@(context.ExcludeFromSync ? Color.Success : Color.Warning)" Size="Size.Small" OnClick="() => ToggleSyncExclusionAsync(context)">@(context.ExcludeFromSync ? "Enable Sync" : "Exclude Sync")</MudButton>
                <MudButton Variant="Variant.Text" Color="@(context.HiddenFromTable ? Color.Success : Color.Secondary)" Size="Size.Small" OnClick="() => ToggleHiddenAsync(context)">@(context.HiddenFromTable ? "Unhide" : "Hide")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteComputerAsync(context.Id)">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No computers found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page"
                           InfoFormat="{first_item}-{last_item} of {all_items}"
                           PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<TrackedComputerDto>? _computersTable;
    private List<TrackedPersonDto> _people = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string _searchText = string.Empty;
    private string _assignmentFilter = "all";
    private string _visibilityFilter = "visible";
    private int _rowsPerPage = 25;

    private string _newHostname = string.Empty;
    private string _newAssetTag = string.Empty;
    private TrackedPersonDto? _selectedPerson;
    private int? _selectedPersonId;

    private int? _editingComputerId;
    private string _editHostname = string.Empty;
    private string _editAssetTag = string.Empty;
    private TrackedPersonDto? _editSelectedPerson;
    private int? _editPersonId;
    private string _editCategory = "Computer";

    private string ComputerFormHostname
    {
        get => _editingComputerId is null ? _newHostname : _editHostname;
        set
        {
            if (_editingComputerId is null)
            {
                _newHostname = value;
            }
            else
            {
                _editHostname = value;
            }
        }
    }

    private string ComputerFormAssetTag
    {
        get => _editingComputerId is null ? _newAssetTag : _editAssetTag;
        set
        {
            if (_editingComputerId is null)
            {
                _newAssetTag = value;
            }
            else
            {
                _editAssetTag = value;
            }
        }
    }

    private TrackedPersonDto? ComputerFormPerson
    {
        get => _editingComputerId is null ? _selectedPerson : _editSelectedPerson;
        set
        {
            if (_editingComputerId is null)
            {
                _selectedPerson = value;
                _selectedPersonId = value?.Id;
            }
            else
            {
                _editSelectedPerson = value;
                _editPersonId = value?.Id;
            }
        }
    }

    private string ComputerFormCategory
    {
        get => _editingComputerId is null ? "Computer" : _editCategory;
        set
        {
            if (_editingComputerId is not null)
            {
                _editCategory = value;
            }
        }
    }

    private static readonly string[] _assignableCategories = ["Computer", "Phone", "Tablet", "Other Device"];

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _people = (await Api.GetPeopleAsync()).ToList();
        _isLoading = false;
    }

    private async Task<TableData<TrackedComputerDto>> LoadComputersServerData(TableState state, CancellationToken cancellationToken)
    {
        _isLoading = true;

        var sortBy = string.IsNullOrWhiteSpace(state.SortLabel) ? "hostname" : state.SortLabel;
        var sortDir = state.SortDirection == SortDirection.Descending ? "desc" : "asc";

        var page = await Api.GetComputersPageAsync(
            page: state.Page + 1,
            pageSize: state.PageSize <= 0 ? _rowsPerPage : state.PageSize,
            search: _searchText,
            sortBy: sortBy,
            sortDir: sortDir,
            filter: _assignmentFilter,
            visibility: _visibilityFilter,
            category: "Computer");

        _isLoading = false;

        return new TableData<TrackedComputerDto>
        {
            Items = page.Items,
            TotalItems = page.TotalCount
        };
    }

    private async Task OnSearchDebounced(string _)
    {
        if (_computersTable is not null)
        {
            _computersTable.NavigateTo(0);
            await _computersTable.ReloadServerData();
        }
    }

    private async Task OnAssignmentFilterChanged(string value)
    {
        _assignmentFilter = string.IsNullOrWhiteSpace(value) ? "all" : value;
        if (_computersTable is not null)
        {
            _computersTable.NavigateTo(0);
            await _computersTable.ReloadServerData();
        }
    }

    private async Task OnVisibilityFilterChanged(string value)
    {
        _visibilityFilter = string.IsNullOrWhiteSpace(value) ? "visible" : value;
        if (_computersTable is not null)
        {
            _computersTable.NavigateTo(0);
            await _computersTable.ReloadServerData();
        }
    }

    private void OnRowsPerPageChanged(int size)
    {
        _rowsPerPage = size;
    }

    private async Task ReloadComputersTableAsync()
    {
        if (_computersTable is not null)
        {
            await _computersTable.ReloadServerData();
        }
    }

    private async Task RefreshPeopleForPickerAsync()
    {
        _people = (await Api.GetPeopleAsync()).ToList();
    }

    private Task<IEnumerable<TrackedPersonDto>> SearchPeopleAsync(string value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();

        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<TrackedPersonDto>>(_people.OrderBy(x => x.FullName).Take(50));
        }

        var term = value.Trim();
        var results = _people
            .Where(person =>
                person.FullName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(person.Email) && person.Email.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(person.MobilePhone) && person.MobilePhone.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(person.BusinessPhone) && person.BusinessPhone.Contains(term, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(x => x.FullName)
            .Take(50);

        return Task.FromResult<IEnumerable<TrackedPersonDto>>(results);
    }

    private string FormatPersonOption(TrackedPersonDto? person)
    {
        if (person is null)
        {
            return string.Empty;
        }

        return string.IsNullOrWhiteSpace(person.Email)
            ? person.FullName
            : $"{person.FullName} ({person.Email})";
    }

    private Task OnComputerPersonChanged(TrackedPersonDto? person)
    {
        ComputerFormPerson = person;
        return Task.CompletedTask;
    }

    private async Task CreateComputerAsync()
    {
        if (string.IsNullOrWhiteSpace(_newHostname) || string.IsNullOrWhiteSpace(_newAssetTag))
        {
            Snackbar.Add("Hostname and Asset Tag are required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.CreateComputerAsync(new CreateTrackedComputerRequest(_newHostname.Trim(), _newAssetTag.Trim(), _selectedPersonId));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to create computer.", Severity.Error);
            return;
        }

        _newHostname = string.Empty;
        _newAssetTag = string.Empty;
        _selectedPerson = null;
        _selectedPersonId = null;
        await RefreshPeopleForPickerAsync();
        await ReloadComputersTableAsync();
        Snackbar.Add("Computer added.", Severity.Success);
    }

    private void BeginEdit(TrackedComputerDto computer)
    {
        _editingComputerId = computer.Id;
        _editHostname = computer.Hostname;
        _editAssetTag = computer.AssetTag;
        _editSelectedPerson = _people.FirstOrDefault(x => x.Id == computer.TrackedPersonId);
        _editPersonId = computer.TrackedPersonId;
        _editCategory = string.IsNullOrWhiteSpace(computer.AssetCategory) ? "Computer" : computer.AssetCategory;
    }

    private void CancelEdit()
    {
        _editingComputerId = null;
        _editHostname = string.Empty;
        _editAssetTag = string.Empty;
        _editSelectedPerson = null;
        _editPersonId = null;
        _editCategory = "Computer";
    }

    private async Task SaveEditAsync()
    {
        if (_editingComputerId is null || string.IsNullOrWhiteSpace(_editHostname) || string.IsNullOrWhiteSpace(_editAssetTag))
        {
            Snackbar.Add("Hostname and Asset Tag are required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var computerId = _editingComputerId.Value;
        var (success, error) = await Api.UpdateComputerAsync(computerId, new CreateTrackedComputerRequest(_editHostname.Trim(), _editAssetTag.Trim(), _editPersonId));
        if (!success)
        {
            _isSaving = false;
            Snackbar.Add(error ?? "Failed to update computer.", Severity.Error);
            return;
        }

        var normalizedCategory = string.IsNullOrWhiteSpace(_editCategory) ? "Computer" : _editCategory;
        var (flagsSuccess, flagsError) = await Api.UpdateComputerFlagsAsync(computerId, new UpdateTrackedComputerFlagsRequest(null, null, normalizedCategory));
        _isSaving = false;

        if (!flagsSuccess)
        {
            Snackbar.Add(flagsError ?? "Failed to update category.", Severity.Error);
            return;
        }

        CancelEdit();
        await RefreshPeopleForPickerAsync();
        await ReloadComputersTableAsync();
        Snackbar.Add("Computer updated.", Severity.Success);
    }

    private async Task ToggleSyncExclusionAsync(TrackedComputerDto computer)
    {
        _isSaving = true;
        var (success, error) = await Api.UpdateComputerFlagsAsync(computer.Id, new UpdateTrackedComputerFlagsRequest(!computer.ExcludeFromSync, null, null));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to update sync exclusion.", Severity.Error);
            return;
        }

        await ReloadComputersTableAsync();
        Snackbar.Add(computer.ExcludeFromSync ? "Sync re-enabled for computer." : "Computer excluded from sync.", Severity.Success);
    }

    private async Task ToggleHiddenAsync(TrackedComputerDto computer)
    {
        _isSaving = true;
        var (success, error) = await Api.UpdateComputerFlagsAsync(computer.Id, new UpdateTrackedComputerFlagsRequest(null, !computer.HiddenFromTable, null));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to update hidden status.", Severity.Error);
            return;
        }

        await ReloadComputersTableAsync();
        Snackbar.Add(computer.HiddenFromTable ? "Computer is visible again." : "Computer hidden from table.", Severity.Success);
    }

    private async Task DeleteComputerAsync(int id)
    {
        var parameters = new DialogParameters<web.Components.Dialogs.ConfirmDeleteDialog>
        {
            { x => x.Message, "Soft delete this computer?" }
        };

        var options = new DialogOptions { NoHeader = true, CloseButton = false };
        var dialog = await DialogService.ShowAsync<web.Components.Dialogs.ConfirmDeleteDialog>(string.Empty, parameters, options);
        var confirm = await dialog.Result;
        if (confirm is null || confirm.Canceled)
        {
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.DeleteComputerAsync(id);
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to delete computer.", Severity.Error);
            return;
        }

        if (_editingComputerId == id)
        {
            CancelEdit();
        }

        await RefreshPeopleForPickerAsync();
        await ReloadComputersTableAsync();
        Snackbar.Add("Computer soft-deleted.", Severity.Success);
    }
}

