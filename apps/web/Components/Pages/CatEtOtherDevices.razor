@page "/assets/other-devices"
@inject CatEtApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Other Devices</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Company Assets - Other Devices</MudText>

@if (_editingDeviceId is not null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Edit Device</MudText>
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_editHostname" Label="Hostname" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_editAssetTag" Label="Asset Tag" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int?" @bind-Value="_editPersonId" Label="Assigned User" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((int?)null)">Unassigned</MudSelectItem>
                    @foreach (var person in _people)
                    {
                        <MudSelectItem Value="@((int?)person.Id)">@person.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string" @bind-Value="_editCategory" Label="Category" Variant="Variant.Outlined">
                    @foreach (var category in _assignableCategories)
                    {
                        <MudSelectItem Value="@category">@category</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveEditAsync" Disabled="_isSaving">Update</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" OnClick="CancelEdit" Disabled="_isSaving">Cancel</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

<MudPaper Class="pa-2" Elevation="1">
    <MudGrid Class="pa-2">
        <MudItem xs="12" md="9">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search hostname, asset tag, or assigned user"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          OnDebounceIntervalElapsed="OnSearchDebounced"
                          DebounceInterval="350" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Value="_visibilityFilter"
                       ValueChanged="OnVisibilityFilterChanged"
                       Label="Visibility"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value='@("visible")'>Visible only</MudSelectItem>
                <MudSelectItem Value='@("all")'>All</MudSelectItem>
                <MudSelectItem Value='@("hidden")'>Hidden only</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>

    <MudTable T="TrackedComputerDto"
              @ref="_table"
              ServerData="LoadServerData"
              Dense="true"
              Hover="true"
              Loading="_isLoading"
              RowsPerPage="25">
        <HeaderContent>
            <MudTh>Hostname</MudTh>
            <MudTh>Asset Tag</MudTh>
            <MudTh>Assigned User</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Sync</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Hostname</MudTd>
            <MudTd>@context.AssetTag</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.TrackedPersonName) ? "Unassigned" : context.TrackedPersonName)</MudTd>
            <MudTd>@context.AssetCategory</MudTd>
            <MudTd>@(context.ExcludeFromSync ? "Excluded" : "Enabled")</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => BeginEdit(context)">Edit</MudButton>
                <MudButton Variant="Variant.Text" Color="@(context.ExcludeFromSync ? Color.Success : Color.Warning)" Size="Size.Small" OnClick="() => ToggleSyncAsync(context)">@(context.ExcludeFromSync ? "Enable Sync" : "Exclude Sync")</MudButton>
                <MudButton Variant="Variant.Text" Color="@(context.HiddenFromTable ? Color.Success : Color.Secondary)" Size="Size.Small" OnClick="() => ToggleHiddenAsync(context)">@(context.HiddenFromTable ? "Unhide" : "Hide")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteDeviceAsync(context.Id)">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No other devices found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page"
                           InfoFormat="{first_item}-{last_item} of {all_items}"
                           PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<TrackedComputerDto>? _table;
    private bool _isLoading;
    private bool _isSaving;
    private List<TrackedPersonDto> _people = [];

    private string _searchText = string.Empty;
    private string _visibilityFilter = "visible";

    private int? _editingDeviceId;
    private string _editHostname = string.Empty;
    private string _editAssetTag = string.Empty;
    private int? _editPersonId;
    private string _editCategory = "Other Device";

    private static readonly string[] _assignableCategories = ["Other Device", "Phone", "Tablet", "Computer"];

    protected override async Task OnInitializedAsync()
    {
        _people = (await Api.GetPeopleAsync()).ToList();
    }

    private async Task<TableData<TrackedComputerDto>> LoadServerData(TableState state, CancellationToken token)
    {
        _isLoading = true;

        var page = await Api.GetComputersPageAsync(
            page: state.Page + 1,
            pageSize: state.PageSize <= 0 ? 25 : state.PageSize,
            search: _searchText,
            sortBy: string.IsNullOrWhiteSpace(state.SortLabel) ? "hostname" : state.SortLabel,
            sortDir: state.SortDirection == SortDirection.Descending ? "desc" : "asc",
            visibility: _visibilityFilter,
            category: "other",
            filter: "all");

        _isLoading = false;

        return new TableData<TrackedComputerDto>
        {
            Items = page.Items,
            TotalItems = page.TotalCount
        };
    }

    private async Task OnSearchDebounced(string _)
    {
        if (_table is null) return;
        _table.NavigateTo(0);
        await _table.ReloadServerData();
    }

    private async Task OnVisibilityFilterChanged(string value)
    {
        _visibilityFilter = string.IsNullOrWhiteSpace(value) ? "visible" : value;
        if (_table is null) return;
        _table.NavigateTo(0);
        await _table.ReloadServerData();
    }

    private void BeginEdit(TrackedComputerDto device)
    {
        _editingDeviceId = device.Id;
        _editHostname = device.Hostname;
        _editAssetTag = device.AssetTag;
        _editPersonId = device.TrackedPersonId;
        _editCategory = string.IsNullOrWhiteSpace(device.AssetCategory) ? "Other Device" : device.AssetCategory;
    }

    private void CancelEdit()
    {
        _editingDeviceId = null;
        _editHostname = string.Empty;
        _editAssetTag = string.Empty;
        _editPersonId = null;
        _editCategory = "Other Device";
    }

    private async Task SaveEditAsync()
    {
        if (_editingDeviceId is null || string.IsNullOrWhiteSpace(_editHostname) || string.IsNullOrWhiteSpace(_editAssetTag))
        {
            Snackbar.Add("Hostname and Asset Tag are required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var id = _editingDeviceId.Value;
        var (success, error) = await Api.UpdateComputerAsync(id, new CreateTrackedComputerRequest(_editHostname.Trim(), _editAssetTag.Trim(), _editPersonId));
        if (!success)
        {
            _isSaving = false;
            Snackbar.Add(error ?? "Failed to update device.", Severity.Error);
            return;
        }

        var normalizedCategory = string.IsNullOrWhiteSpace(_editCategory) ? "Other Device" : _editCategory;
        var (flagsSuccess, flagsError) = await Api.UpdateComputerFlagsAsync(id, new UpdateTrackedComputerFlagsRequest(null, null, normalizedCategory));
        _isSaving = false;

        if (!flagsSuccess)
        {
            Snackbar.Add(flagsError ?? "Failed to update category.", Severity.Error);
            return;
        }

        CancelEdit();
        _people = (await Api.GetPeopleAsync()).ToList();
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }

        Snackbar.Add("Device updated.", Severity.Success);
    }

    private async Task ToggleSyncAsync(TrackedComputerDto device)
    {
        var (ok, err) = await Api.UpdateComputerFlagsAsync(device.Id, new UpdateTrackedComputerFlagsRequest(!device.ExcludeFromSync, null, null));
        if (!ok)
        {
            Snackbar.Add(err ?? "Failed to update sync setting.", Severity.Error);
            return;
        }

        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task ToggleHiddenAsync(TrackedComputerDto device)
    {
        var (ok, err) = await Api.UpdateComputerFlagsAsync(device.Id, new UpdateTrackedComputerFlagsRequest(null, !device.HiddenFromTable, null));
        if (!ok)
        {
            Snackbar.Add(err ?? "Failed to update visibility.", Severity.Error);
            return;
        }

        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task DeleteDeviceAsync(int id)
    {
        var parameters = new DialogParameters<web.Components.Dialogs.ConfirmDeleteDialog>
        {
            { x => x.Message, "Soft delete this device?" }
        };

        var options = new DialogOptions { NoHeader = true, CloseButton = false };
        var dialog = await DialogService.ShowAsync<web.Components.Dialogs.ConfirmDeleteDialog>(string.Empty, parameters, options);
        var confirm = await dialog.Result;
        if (confirm is null || confirm.Canceled)
        {
            return;
        }

        var (success, error) = await Api.DeleteComputerAsync(id);
        if (!success)
        {
            Snackbar.Add(error ?? "Failed to delete device.", Severity.Error);
            return;
        }

        if (_editingDeviceId == id)
        {
            CancelEdit();
        }

        _people = (await Api.GetPeopleAsync()).ToList();
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }

        Snackbar.Add("Device soft-deleted.", Severity.Success);
    }
}
