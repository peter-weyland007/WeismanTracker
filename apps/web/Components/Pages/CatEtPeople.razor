@page "/assets/users"
@inject CatEtApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>CAT ET People</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">CAT ET - People</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-3">Add Person</MudText>
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_newFullName" Label="Full name" Variant="Variant.Outlined" Required="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_newEmail" Label="Email (optional)" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_newMobilePhone" Label="Mobile phone" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField @bind-Value="_newBusinessPhone" Label="Business phone" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="CreatePersonAsync" Disabled="_isSaving">Add</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_editingPersonId is not null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Edit Person</MudText>
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_editFullName" Label="Full name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_editEmail" Label="Email (optional)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="_editMobilePhone" Label="Mobile phone" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="_editBusinessPhone" Label="Business phone" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveEditAsync" Disabled="_isSaving">Update</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" OnClick="CancelEdit" Disabled="_isSaving">Cancel</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

<MudPaper Class="pa-2" Elevation="1">
    <MudGrid Class="pa-2">
        <MudItem xs="12" md="8">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search name, email, or phone"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          OnDebounceIntervalElapsed="OnSearchDebounced"
                          DebounceInterval="350" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string"
                       Value="_emailFilter"
                       ValueChanged="OnEmailFilterChanged"
                       Label="Email filter"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value='@("all")'>All people</MudSelectItem>
                <MudSelectItem Value='@("withEmail")'>With email</MudSelectItem>
                <MudSelectItem Value='@("withoutEmail")'>Without email</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>
    <MudTable T="TrackedPersonDto"
              @ref="_peopleTable"
              ServerData="LoadPeopleServerData"
              Hover="true"
              Dense="true"
              Loading="_isLoading"
              RowsPerPage="25"
              RowsPerPageChanged="OnRowsPerPageChanged">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="TrackedPersonDto" SortLabel="fullName">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedPersonDto" SortLabel="email">Email</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedPersonDto" SortLabel="mobilePhone">Mobile</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedPersonDto" SortLabel="businessPhone">Business</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="TrackedPersonDto" SortLabel="createdAt">Created (UTC)</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Email) ? "-" : context.Email)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.MobilePhone) ? "-" : context.MobilePhone)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.BusinessPhone) ? "-" : context.BusinessPhone)</MudTd>
            <MudTd>@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => BeginEdit(context)">Edit</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeletePersonAsync(context.Id)">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No people found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page"
                           InfoFormat="{first_item}-{last_item} of {all_items}"
                           PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<TrackedPersonDto>? _peopleTable;
    private bool _isLoading = true;
    private bool _isSaving;

    private string _searchText = string.Empty;
    private string _emailFilter = "all";
    private int _rowsPerPage = 25;

    private string _newFullName = string.Empty;
    private string _newEmail = string.Empty;
    private string _newMobilePhone = string.Empty;
    private string _newBusinessPhone = string.Empty;

    private int? _editingPersonId;
    private string _editFullName = string.Empty;
    private string _editEmail = string.Empty;
    private string _editMobilePhone = string.Empty;
    private string _editBusinessPhone = string.Empty;

    private async Task<TableData<TrackedPersonDto>> LoadPeopleServerData(TableState state, CancellationToken cancellationToken)
    {
        _isLoading = true;

        var sortBy = string.IsNullOrWhiteSpace(state.SortLabel) ? "fullName" : state.SortLabel;
        var sortDir = state.SortDirection == SortDirection.Descending ? "desc" : "asc";

        var page = await Api.GetPeoplePageAsync(
            page: state.Page + 1,
            pageSize: state.PageSize <= 0 ? _rowsPerPage : state.PageSize,
            search: _searchText,
            sortBy: sortBy,
            sortDir: sortDir,
            filter: _emailFilter);

        _isLoading = false;

        return new TableData<TrackedPersonDto>
        {
            Items = page.Items,
            TotalItems = page.TotalCount
        };
    }

    private async Task OnSearchDebounced(string _)
    {
        if (_peopleTable is not null)
        {
            _peopleTable.NavigateTo(0);
            await _peopleTable.ReloadServerData();
        }
    }

    private async Task OnEmailFilterChanged(string value)
    {
        _emailFilter = string.IsNullOrWhiteSpace(value) ? "all" : value;
        if (_peopleTable is not null)
        {
            _peopleTable.NavigateTo(0);
            await _peopleTable.ReloadServerData();
        }
    }

    private void OnRowsPerPageChanged(int size)
    {
        _rowsPerPage = size;
    }

    private async Task ReloadPeopleTableAsync()
    {
        if (_peopleTable is not null)
        {
            await _peopleTable.ReloadServerData();
        }
    }

    private async Task CreatePersonAsync()
    {
        if (string.IsNullOrWhiteSpace(_newFullName))
        {
            Snackbar.Add("Full name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.CreatePersonAsync(new CreateTrackedPersonRequest(
            _newFullName.Trim(),
            string.IsNullOrWhiteSpace(_newEmail) ? null : _newEmail.Trim(),
            string.IsNullOrWhiteSpace(_newMobilePhone) ? null : _newMobilePhone.Trim(),
            string.IsNullOrWhiteSpace(_newBusinessPhone) ? null : _newBusinessPhone.Trim()));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to create person.", Severity.Error);
            return;
        }

        _newFullName = string.Empty;
        _newEmail = string.Empty;
        _newMobilePhone = string.Empty;
        _newBusinessPhone = string.Empty;
        await ReloadPeopleTableAsync();
        Snackbar.Add("Person added.", Severity.Success);
    }

    private void BeginEdit(TrackedPersonDto person)
    {
        _editingPersonId = person.Id;
        _editFullName = person.FullName;
        _editEmail = person.Email ?? string.Empty;
        _editMobilePhone = person.MobilePhone ?? string.Empty;
        _editBusinessPhone = person.BusinessPhone ?? string.Empty;
    }

    private void CancelEdit()
    {
        _editingPersonId = null;
        _editFullName = string.Empty;
        _editEmail = string.Empty;
        _editMobilePhone = string.Empty;
        _editBusinessPhone = string.Empty;
    }

    private async Task SaveEditAsync()
    {
        if (_editingPersonId is null || string.IsNullOrWhiteSpace(_editFullName))
        {
            Snackbar.Add("Full name is required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.UpdatePersonAsync(_editingPersonId.Value, new CreateTrackedPersonRequest(
            _editFullName.Trim(),
            string.IsNullOrWhiteSpace(_editEmail) ? null : _editEmail.Trim(),
            string.IsNullOrWhiteSpace(_editMobilePhone) ? null : _editMobilePhone.Trim(),
            string.IsNullOrWhiteSpace(_editBusinessPhone) ? null : _editBusinessPhone.Trim()));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to update person.", Severity.Error);
            return;
        }

        CancelEdit();
        await ReloadPeopleTableAsync();
        Snackbar.Add("Person updated.", Severity.Success);
    }

    private async Task DeletePersonAsync(int id)
    {
        var parameters = new DialogParameters<web.Components.Dialogs.ConfirmDeleteDialog>
        {
            { x => x.Message, "Soft delete this person?" }
        };

        var options = new DialogOptions { NoHeader = true, CloseButton = false };
        var dialog = await DialogService.ShowAsync<web.Components.Dialogs.ConfirmDeleteDialog>(string.Empty, parameters, options);
        var confirm = await dialog.Result;
        if (confirm is null || confirm.Canceled)
        {
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.DeletePersonAsync(id);
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to delete person.", Severity.Error);
            return;
        }

        if (_editingPersonId == id)
        {
            CancelEdit();
        }

        await ReloadPeopleTableAsync();
        Snackbar.Add("Person soft-deleted.", Severity.Success);
    }
}
