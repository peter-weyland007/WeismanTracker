@page "/allowances/cell-phone"
@attribute [Authorize(Policy = AppPermissions.CellPhoneAllowance)]
@inject CatEtApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime

<PageTitle>Cell Phone Allowance Tracker</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Cell Phone Allowance Tracker</MudText>

<MudPaper Class="pa-4 mb-4 people-form-card" Elevation="1">
    <div class="people-form-header">
        <div>
            <MudText Typo="Typo.h6">@(_editingAllowanceId is null ? "Add Allowance Record" : "Edit Allowance Record")</MudText>
            <MudText Typo="Typo.body2" Class="text-secondary mb-4">@(_editingAllowanceId is null ? "Track who receives a mobile allowance and when it was approved." : "Update the allowance record in the same form without opening a second card.")</MudText>
        </div>
        @if (_editingAllowanceId is not null)
        {
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Editing record</MudChip>
        }
    </div>
    <MudGrid Spacing="3" Class="people-form-grid">
        <MudItem xs="12" sm="6" lg="3">
            <MudAutocomplete T="TrackedPersonDto"
                             Value="AllowanceFormPerson"
                             ValueChanged="OnAllowancePersonChanged"
                             Label="User"
                             Variant="Variant.Outlined"
                             Required="true"
                             SearchFunc="SearchPeopleAsync"
                             ToStringFunc="FormatPersonOption"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             CoerceText="false"
                             Dense="true"
                             MaxItems="50"
                             Placeholder="Type to filter users" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudTextField @bind-Value="AllowanceFormMobilePhoneNumber" Label="Mobile phone number" Variant="Variant.Outlined" Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2" Class="d-flex align-center">
            <MudSwitch T="bool" @bind-Value="AllowanceFormGranted" Color="Color.Success" Label="Allowance granted" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <MudDatePicker @bind-Date="AllowanceFormApprovedAt" Label="Approved date" Variant="Variant.Outlined" Editable="true" DateFormat="yyyy-MM-dd" />
        </MudItem>
        <MudItem xs="12" lg="2">
            <div class="people-form-actions">
                @if (_editingAllowanceId is not null)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" Class="people-form-secondary-action" OnClick="CancelEdit" Disabled="_isSaving">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="people-form-action" OnClick="SaveEditAsync" Disabled="_isSaving">Save changes</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="people-form-action" OnClick="CreateAllowanceAsync" Disabled="_isSaving">Add allowance</MudButton>
                }
            </div>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-2" Elevation="1">
    <MudGrid Class="pa-2">
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search user, email, or phone"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          OnDebounceIntervalElapsed="OnSearchDebounced"
                          DebounceInterval="350" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Value="_statusFilter"
                       ValueChanged="OnStatusFilterChanged"
                       Label="Allowance filter"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem Value='@("all")'>All records</MudSelectItem>
                <MudSelectItem Value='@("granted")'>Granted only</MudSelectItem>
                <MudSelectItem Value='@("notGranted")'>Not granted</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3" Class="d-flex align-center justify-end">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportToExcelAsync"
                       Disabled="_isExporting"
                       Class="mt-2 mt-md-0">
                @(_isExporting ? "Exporting..." : "Export Excel")
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudTable T="CellPhoneAllowanceDto"
              @ref="_table"
              ServerData="LoadAllowancesServerData"
              Hover="true"
              Dense="true"
              Loading="_isLoading"
              RowsPerPage="25"
              RowsPerPageChanged="OnRowsPerPageChanged">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="CellPhoneAllowanceDto" SortLabel="person">User</MudTableSortLabel></MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Payroll Group</MudTh>
            <MudTh><MudTableSortLabel T="CellPhoneAllowanceDto" SortLabel="mobileNumber">Mobile phone</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CellPhoneAllowanceDto" SortLabel="granted">Granted</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CellPhoneAllowanceDto" SortLabel="approvedAt">Approved date</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CellPhoneAllowanceDto" SortLabel="createdAt">Created (UTC)</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@FormatAllowancePerson(context)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.TrackedPersonEmail) ? "-" : context.TrackedPersonEmail)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.TrackedPersonPayrollGroupLabel) ? "-" : context.TrackedPersonPayrollGroupLabel)</MudTd>
            <MudTd>@context.MobilePhoneNumber</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.AllowanceGranted ? Color.Success : Color.Default)" Variant="Variant.Filled" Size="Size.Small">
                    @(context.AllowanceGranted ? "Granted" : "Not granted")
                </MudChip>
            </MudTd>
            <MudTd>@(context.ApprovedAtUtc?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
            <MudTd>@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="() => BeginEdit(context)">Edit</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteAllowanceAsync(context.Id)">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No cell phone allowance records found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page"
                           InfoFormat="{first_item}-{last_item} of {all_items}"
                           PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<CellPhoneAllowanceDto>? _table;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isExporting;
    private int _rowsPerPage = 25;
    private string _searchText = string.Empty;
    private string _statusFilter = "all";
    private List<TrackedPersonDto> _people = [];

    private TrackedPersonDto? _newSelectedPerson;
    private int? _newTrackedPersonId;
    private string _newMobilePhoneNumber = string.Empty;
    private bool _newAllowanceGranted;
    private DateTime? _newApprovedAt;

    private int? _editingAllowanceId;
    private TrackedPersonDto? _editSelectedPerson;
    private int? _editTrackedPersonId;
    private string _editMobilePhoneNumber = string.Empty;
    private bool _editAllowanceGranted;
    private DateTime? _editApprovedAt;

    private TrackedPersonDto? AllowanceFormPerson
    {
        get => _editingAllowanceId is null ? _newSelectedPerson : _editSelectedPerson;
        set
        {
            if (_editingAllowanceId is null)
            {
                _newSelectedPerson = value;
                _newTrackedPersonId = value?.Id;
                _newMobilePhoneNumber = value?.MobilePhone ?? string.Empty;
            }
            else
            {
                _editSelectedPerson = value;
                _editTrackedPersonId = value?.Id;
                _editMobilePhoneNumber = value?.MobilePhone ?? string.Empty;
            }
        }
    }

    private string AllowanceFormMobilePhoneNumber
    {
        get => _editingAllowanceId is null ? _newMobilePhoneNumber : _editMobilePhoneNumber;
        set
        {
            if (_editingAllowanceId is null)
            {
                _newMobilePhoneNumber = value;
            }
            else
            {
                _editMobilePhoneNumber = value;
            }
        }
    }

    private bool AllowanceFormGranted
    {
        get => _editingAllowanceId is null ? _newAllowanceGranted : _editAllowanceGranted;
        set
        {
            if (_editingAllowanceId is null)
            {
                _newAllowanceGranted = value;
            }
            else
            {
                _editAllowanceGranted = value;
            }
        }
    }

    private DateTime? AllowanceFormApprovedAt
    {
        get => _editingAllowanceId is null ? _newApprovedAt : _editApprovedAt;
        set
        {
            if (_editingAllowanceId is null)
            {
                _newApprovedAt = value;
            }
            else
            {
                _editApprovedAt = value;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _people = (await Api.GetPeopleAsync())
            .Where(x => !x.IsServiceAccount)
            .OrderBy(x => x.FullName)
            .ToList();
    }

    private async Task<TableData<CellPhoneAllowanceDto>> LoadAllowancesServerData(TableState state, CancellationToken cancellationToken)
    {
        _isLoading = true;

        var sortBy = string.IsNullOrWhiteSpace(state.SortLabel) ? "person" : state.SortLabel;
        var sortDir = state.SortDirection == SortDirection.Descending ? "desc" : "asc";

        var page = await Api.GetCellPhoneAllowancesPageAsync(
            page: state.Page + 1,
            pageSize: state.PageSize <= 0 ? _rowsPerPage : state.PageSize,
            search: _searchText,
            sortBy: sortBy,
            sortDir: sortDir,
            filter: _statusFilter);

        _isLoading = false;

        return new TableData<CellPhoneAllowanceDto>
        {
            Items = page.Items,
            TotalItems = page.TotalCount
        };
    }

    private async Task OnSearchDebounced(string _)
    {
        if (_table is not null)
        {
            _table.NavigateTo(0);
            await _table.ReloadServerData();
        }
    }

    private async Task OnStatusFilterChanged(string value)
    {
        _statusFilter = string.IsNullOrWhiteSpace(value) ? "all" : value;
        if (_table is not null)
        {
            _table.NavigateTo(0);
            await _table.ReloadServerData();
        }
    }

    private void OnRowsPerPageChanged(int size)
    {
        _rowsPerPage = size;
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private Task<IEnumerable<TrackedPersonDto>> SearchPeopleAsync(string value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();

        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<TrackedPersonDto>>(_people.Take(50));
        }

        var term = value.Trim();
        var results = _people
            .Where(person =>
                person.FullName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(person.Email) && person.Email.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(person.EmployeeNumber) && person.EmployeeNumber.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(person.MobilePhone) && person.MobilePhone.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(person.BusinessPhone) && person.BusinessPhone.Contains(term, StringComparison.OrdinalIgnoreCase)))
            .Take(50);

        return Task.FromResult<IEnumerable<TrackedPersonDto>>(results);
    }

    private string FormatPersonOption(TrackedPersonDto? person)
    {
        if (person is null)
        {
            return string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(person.EmployeeNumber))
        {
            return $"{person.FullName} ({person.EmployeeNumber})";
        }

        return string.IsNullOrWhiteSpace(person.Email)
            ? person.FullName
            : $"{person.FullName} ({person.Email})";
    }

    private string FormatAllowancePerson(CellPhoneAllowanceDto allowance)
    {
        return string.IsNullOrWhiteSpace(allowance.TrackedPersonEmployeeNumber)
            ? allowance.TrackedPersonName
            : $"{allowance.TrackedPersonName} ({allowance.TrackedPersonEmployeeNumber})";
    }

    private Task OnAllowancePersonChanged(TrackedPersonDto? person)
    {
        AllowanceFormPerson = person;
        return Task.CompletedTask;
    }

    private async Task CreateAllowanceAsync()
    {
        if (_newTrackedPersonId is null)
        {
            Snackbar.Add("User is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newMobilePhoneNumber))
        {
            Snackbar.Add("Mobile phone number is required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.CreateCellPhoneAllowanceAsync(new CreateCellPhoneAllowanceRequest(
            _newTrackedPersonId.Value,
            _newMobilePhoneNumber.Trim(),
            _newAllowanceGranted,
            _newApprovedAt));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to create allowance record.", Severity.Error);
            return;
        }

        _newSelectedPerson = null;
        _newTrackedPersonId = null;
        _newMobilePhoneNumber = string.Empty;
        _newAllowanceGranted = false;
        _newApprovedAt = null;
        await ReloadTableAsync();
        Snackbar.Add("Allowance record added.", Severity.Success);
    }

    private void BeginEdit(CellPhoneAllowanceDto allowance)
    {
        _editingAllowanceId = allowance.Id;
        _editSelectedPerson = _people.FirstOrDefault(x => x.Id == allowance.TrackedPersonId);
        _editTrackedPersonId = allowance.TrackedPersonId;
        _editMobilePhoneNumber = allowance.MobilePhoneNumber;
        _editAllowanceGranted = allowance.AllowanceGranted;
        _editApprovedAt = allowance.ApprovedAtUtc;
    }

    private void CancelEdit()
    {
        _editingAllowanceId = null;
        _editSelectedPerson = null;
        _editTrackedPersonId = null;
        _editMobilePhoneNumber = string.Empty;
        _editAllowanceGranted = false;
        _editApprovedAt = null;
    }

    private async Task SaveEditAsync()
    {
        if (_editingAllowanceId is null || _editTrackedPersonId is null)
        {
            Snackbar.Add("User is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editMobilePhoneNumber))
        {
            Snackbar.Add("Mobile phone number is required.", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.UpdateCellPhoneAllowanceAsync(_editingAllowanceId.Value, new CreateCellPhoneAllowanceRequest(
            _editTrackedPersonId.Value,
            _editMobilePhoneNumber.Trim(),
            _editAllowanceGranted,
            _editApprovedAt));
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to update allowance record.", Severity.Error);
            return;
        }

        CancelEdit();
        await ReloadTableAsync();
        Snackbar.Add("Allowance record updated.", Severity.Success);
    }

    private async Task ExportToExcelAsync()
    {
        try
        {
            _isExporting = true;
            var (content, fileName) = await Api.ExportCellPhoneAllowancesAsync(_searchText, _statusFilter);
            var base64 = Convert.ToBase64String(content);
            await JsRuntime.InvokeVoidAsync("window.fileDownloads.downloadBytes", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
            Snackbar.Add("Allowance export downloaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task DeleteAllowanceAsync(int id)
    {
        var parameters = new DialogParameters<web.Components.Dialogs.ConfirmDeleteDialog>
        {
            { x => x.Message, "Soft delete this allowance record?" }
        };

        var options = new DialogOptions { NoHeader = true, CloseButton = false };
        var dialog = await DialogService.ShowAsync<web.Components.Dialogs.ConfirmDeleteDialog>(string.Empty, parameters, options);
        var confirm = await dialog.Result;
        if (confirm is null || confirm.Canceled)
        {
            return;
        }

        _isSaving = true;
        var (success, error) = await Api.DeleteCellPhoneAllowanceAsync(id);
        _isSaving = false;

        if (!success)
        {
            Snackbar.Add(error ?? "Failed to delete allowance record.", Severity.Error);
            return;
        }

        if (_editingAllowanceId == id)
        {
            CancelEdit();
        }

        await ReloadTableAsync();
        Snackbar.Add("Allowance record deleted.", Severity.Success);
    }
}
