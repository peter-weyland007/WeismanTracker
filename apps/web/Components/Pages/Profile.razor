@page "/profile"
@attribute [Authorize]
@inject CatEtApiClient Api
@inject ApiAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Profile</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">My Profile</MudText>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_profile is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Unable to load your profile.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6">Account</MudText>
                <MudDivider Class="my-2" />
                <MudStack Spacing="1">
                    <MudText><strong>Username:</strong> @_profile.Username</MudText>
                    <MudText><strong>Role:</strong> @_profile.Role</MudText>
                    <MudText><strong>Status:</strong> @(_profile.IsEnabled ? "Enabled" : "Disabled")</MudText>
                    <MudText><strong>Created (UTC):</strong> @_profile.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6">Page Access</MudText>
                <MudDivider Class="my-2" />
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var permission in _profile.Permissions)
                    {
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@GetPermissionLabel(permission)</MudChip>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6">Change Password</MudText>
                <MudText Typo="Typo.body2" Class="text-secondary mb-4">Passwords must be at least 8 characters.</MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_currentPassword" Label="Current password" Variant="Variant.Outlined" InputType="InputType.Password" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_newPassword" Label="New password" Variant="Variant.Outlined" InputType="InputType.Password" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_confirmPassword" Label="Confirm new password" Variant="Variant.Outlined" InputType="InputType.Password" Required="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePasswordAsync" Disabled="_isSaving">Update password</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private static readonly Dictionary<string, string> PermissionLabels = new(StringComparer.OrdinalIgnoreCase)
    {
        [AppPermissions.People] = "People",
        [AppPermissions.Computers] = "Computers",
        [AppPermissions.Printers] = "Printers",
        [AppPermissions.MobileDevices] = "Mobile Devices",
        [AppPermissions.OtherDevices] = "Other Devices",
        [AppPermissions.CellPhoneAllowance] = "Cell Phone Allowance",
        [AppPermissions.ActivationKeys] = "Activation Keys",
        [AppPermissions.ActivityTracker] = "Activity Tracker",
        [AppPermissions.Integrations] = "Integrations",
        [AppPermissions.HardDelete] = "Hard Delete",
        [AppPermissions.UserAccess] = "User Access"
    };

    private bool _isLoading = true;
    private bool _isSaving;
    private ProfileDto? _profile;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        try
        {
            _profile = await Api.GetProfileAsync();
        }
        catch
        {
            _profile = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            Snackbar.Add("Current password is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("New password is required.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("New password must be at least 8 characters.", Severity.Warning);
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            Snackbar.Add("New password confirmation does not match.", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            var result = await Api.ChangeOwnPasswordAsync(new ChangeOwnPasswordRequest(_currentPassword, _newPassword));
            if (!result.Success)
            {
                Snackbar.Add(result.Error ?? "Failed to update password.", Severity.Error);
                return;
            }

            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
            Snackbar.Add("Password updated. Please sign in again.", Severity.Success);
            await AuthStateProvider.SignOutAsync();
            Navigation.NavigateTo("/login", true);
        }
        catch
        {
            Snackbar.Add("Failed to update password.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string GetPermissionLabel(string permission)
        => PermissionLabels.TryGetValue(permission, out var label) ? label : permission;
}
